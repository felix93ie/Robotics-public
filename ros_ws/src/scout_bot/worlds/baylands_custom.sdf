    <!-- Custom Hill 1 (Area of Interest 1) -->
    <!-- Twice as wide (radii: 40m, 40m) and 4x higher (height: 18m, radii: 20m, pose z: -1.5) -->
    <model name="hill_1">
      <static>true</static>
      <pose>126.782 179.08 -35.45 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>53.45</radius>
            </sphere>
          </geometry>
        </collision>
