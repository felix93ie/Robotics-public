            <sphere>
              <radius>53.45</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1.0</ambient>
            <diffuse>1.0 1.0 1.0 1.0</diffuse>
            <specular>0.1 0.1 0.1 1.0</specular>
            <pbr>
              <metal>
                <albedo_map>https://fuel.gazebosim.org/1.0/openrobotics/models/baylands/3/files/media/Textures/Grass.png</albedo_map>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

